# ================================================
# SHAKTI — Environment Configuration
# Copy this file to .env and update values
# ================================================

# ================================================
# DATABASE (PostgreSQL 15)
# ================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shakti_db
DB_USER=shakti_admin
DB_PASSWORD=localdevpassword
DATABASE_URL=postgresql://shakti_admin:localdevpassword@localhost:5432/shakti_db

# ================================================
# AUTHENTICATION (JWT)
# ================================================
JWT_SECRET=replace-with-a-unique-32-plus-character-secret-before-running
JWT_ADMIN_SECRET=replace-with-a-different-32-plus-character-admin-secret-before-running
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=7
REFRESH_COOKIE_NAME=shakti_refresh
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_SECURE=false
JWT_ADMIN_ACCESS_EXPIRY=10m
JWT_ADMIN_REFRESH_EXPIRY_DAYS=7
ADMIN_REFRESH_COOKIE_NAME=shakti_admin_refresh
ADMIN_REFRESH_COOKIE_SAMESITE=strict
ADMIN_REFRESH_COOKIE_SECURE=false
ADMIN_REQUIRE_TOTP=false
ADMIN_REQUIRE_TOTP_ROLES=it_admin
ADMIN_RECENT_AUTH_WINDOW_MINUTES=15
ADMIN_NETWORK_RESTRICTION_MODE=disabled
ADMIN_ALLOWED_IPS=
ADMIN_PROXY_HEADER=x-shakti-admin-proxy
ADMIN_PROXY_HEADER_VALUE=internal
ADMIN_SESSION_RETENTION_DAYS=30
ADMIN_REFRESH_TOKEN_RETENTION_DAYS=30
ADMIN_ACTION_LOG_RETENTION_DAYS=180
ADMIN_RETENTION_JOB_INTERVAL_MINUTES=360
ADMIN_ALERT_FAILED_LOGIN_THRESHOLD=3
ADMIN_ALERT_FILE_DELETION_THRESHOLD=3
ADMIN_ALERT_INGESTION_FAILURE_THRESHOLD=5
ADMIN_ALERT_STALLED_SESSION_THRESHOLD=2
ADMIN_ALERT_STALLED_SESSION_AGE_MINUTES=720
ADMIN_EXPORT_MAX_ROWS=10000
ADMIN_EXPORT_WATERMARK_LABEL=SHAKTI INTERNAL EXPORT
BCRYPT_ROUNDS=12

# ================================================
# OLLAMA (Host-local LLM)
# The backend/AI Docker containers reach the host runtime through
# `host.docker.internal:11434`, while local tools on Windows use `localhost:11434`.
# ================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3.5
OLLAMA_TIMEOUT=60000
OLLAMA_CHAT_NUM_PREDICT=192
OLLAMA_SQL_NUM_PREDICT=128
OLLAMA_ANALYSIS_NUM_PREDICT=224

# ================================================
# CHATBOT CONFIGURATION
# ================================================
CHATBOT_MAX_MESSAGE_LENGTH=4000
CHATBOT_HISTORY_LIMIT=5
CHATBOT_SESSION_MAX_MESSAGES=5
CHATBOT_SESSION_TTL_MS=1800000
CHATBOT_SCHEMA_CACHE_TTL_MS=300000
CHATBOT_RAG_ENABLED=true
CHATBOT_RAG_TOP_K=3
CHATBOT_RAG_MAX_CHARS=3500
CHATBOT_LOG_TO_DB=true
CHATBOT_CONFIDENCE_ENABLED=true
CHATBOT_DIAGNOSTICS_ENABLED=true
CHATBOT_RATE_LIMIT_ENABLED=true
CHATBOT_RATE_LIMIT_WINDOW_MS=60000
CHATBOT_RATE_LIMIT_MAX=60

# ================================================
# AUDIT LOGGING
# ================================================
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_MAX_DETAILS=8000

# ================================================
# BACKEND SERVER
# ================================================
BACKEND_PORT=3001
NODE_ENV=development
DB_AUTO_SEED=false
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ================================================
# CONTROLLED BOOTSTRAP (IDENTITIES ONLY)
# Used by: npm run db:bootstrap-identities
# ================================================
BOOTSTRAP_ADMIN_EMAIL=it.admin@police.gov.in
BOOTSTRAP_ADMIN_FULL_NAME=SHAKTI Bootstrap Administrator
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_ROLE=it_admin
BOOTSTRAP_ADMIN_MUST_CHANGE_PASSWORD=true
BOOTSTRAP_ADMIN_PERMISSIONS=["console_access","admin_overview_read","admin_users_read","admin_audit_read","admin_settings_read"]

# ================================================
# FRONTEND
# ================================================
FRONTEND_PORT=5173
ADMIN_FRONTEND_PORT=4174
VITE_API_URL=http://localhost:3001
VITE_AI_URL=http://localhost:8000
VITE_MAIN_APP_URL=http://localhost:5173
VITE_ADMIN_APP_URL=http://localhost:4174

# ================================================
# AI SERVICES (FastAPI)
# ================================================
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_URL=

# ================================================
# OSINT PROVIDERS (on-prem / internal only)
# Leave disabled unless a real internal provider exists.
# ================================================
OSINT_PHONE_PROVIDER_ENABLED=false
OSINT_PHONE_PROVIDER_URL=
OSINT_PHONE_PROVIDER_METHOD=POST
OSINT_PHONE_PROVIDER_QUERY_PARAM=query
OSINT_PHONE_PROVIDER_TOKEN=
OSINT_PHONE_PROVIDER_TOKEN_HEADER=Authorization
OSINT_PHONE_PROVIDER_TOKEN_PREFIX=Bearer

OSINT_BREACH_PROVIDER_ENABLED=false
OSINT_BREACH_PROVIDER_URL=
OSINT_BREACH_PROVIDER_METHOD=POST
OSINT_BREACH_PROVIDER_QUERY_PARAM=query
OSINT_BREACH_PROVIDER_TOKEN=
OSINT_BREACH_PROVIDER_TOKEN_HEADER=Authorization
OSINT_BREACH_PROVIDER_TOKEN_PREFIX=Bearer

# ================================================
# RATE LIMITING
# ================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=10
ADMIN_AUTH_RATE_LIMIT_MAX_REQUESTS=10

# ================================================
# CORS
# ================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4174,http://localhost:80,http://localhost:3000
ADMIN_ALLOWED_ORIGINS=http://localhost:4174,http://localhost:80,http://localhost:3000

# ================================================
# OBSERVABILITY
# ================================================
METRICS_ENABLED=true
METRICS_BEARER_TOKEN=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
