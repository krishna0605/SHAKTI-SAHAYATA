          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(shakti_http_request_duration_seconds_bucket[$__rate_interval]))) or on() vector(0)",
          "refId": "A"
