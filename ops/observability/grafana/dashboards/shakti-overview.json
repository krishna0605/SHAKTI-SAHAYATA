      "title": "HTTP Requests / sec",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "shakti-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
